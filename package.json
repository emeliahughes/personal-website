{
    "name": "themebau",
    "title": "Emelia Hughes",
    "version": "2.0.1",
    "description": "Themebau is a stylish universal template for all your projects & creative output. Minimalistic and easy to use, it has everything you need to launch your website.",
    "author": "RunWebRun",
    "website": "https://runwebrun.com/",
    "purchase": "https://themes.getbootstrap.com/product/themebau/",
    "support": "runwebrun@gmail.com",
    "license": "You must have a valid license purchased only from Bootstrap in order to legally use the theme for your project.",
    "scripts": {
        "dev": "gulp",
        "build": "gulp production",
        "css-lint": "stylelint --custom-syntax postcss-scss \"src/css/**/*.scss\"",
        "css-lint-fix": "stylelint --fix --custom-syntax postcss-scss \"src/css/**/*.scss\"",
        "js-lint": "eslint src/js/",
        "js-lint-fix": "eslint --fix src/js/"
    },
    "gulp_config": {
        "variables": {
            "template_name": "themebau",
            "src": "./src",
            "dist": "./dist"
        },
        "browserSync": {
            "server": {
                "baseDir": "{dist}"
            },
            "open": true,
            "notify": false
        },
        "static": [
            {
                "from": "{src}/static/**",
                "to": "{dist}"
            },
            {
                "from": "{src}/CNAME",
                "to": "{dist}"
            },
            {
                "from": "{src}/html/data/*.json",
                "to": "{dist}/data"
            },
            {
                "from": "{src}/html/data/pdfs/**",
                "to": "{dist}/data/pdfs"
            },
            {
                "from": "{src}/html/data/images/**",
                "to": "{dist}/data/images"
            },
            {
                "from": [
                    "node_modules/*bootstrap/dist/js/bootstrap.min.js",
                    "node_modules/*bootstrap/dist/js/bootstrap.min.js.map",
                    "node_modules/*bootstrap/dist/css/bootstrap.min.css",
                    "node_modules/*bootstrap/dist/css/bootstrap.min.css.map",
                    "node_modules/*animejs/lib/anime.min.js",
                    "node_modules/*rellax/rellax.min.js",
                    "node_modules/*isotope-layout/dist/isotope.pkgd.min.js",
                    "node_modules/*isotope-packery/packery-mode.pkgd.min.js",
                    "node_modules/@fancyapps/*fancybox/dist/jquery.fancybox.min.js",
                    "node_modules/@fancyapps/*fancybox/dist/jquery.fancybox.min.css",
                    "node_modules/*imagesloaded/imagesloaded.pkgd.min.js",
                    "node_modules/*object-fit-images/dist/ofi.min.js",
                    "node_modules/*jquery/dist/jquery.min.js"
                ],
                "to": "{dist}/assets/vendor"
            }
        ],
        "js": {
            "from": "{src}/js/*.js",
            "to": "{dist}/assets/js"
        },
        "css": {
            "from": "{src}/css/**/*.{sass,scss,css}",
            "to": "{dist}/assets/css",
            "sass": {
                "indentWidth": 4,
                "outputStyle": "expanded"
            }
        },
        "html": {
            "from": "{src}/html/**/*.html",
            "to": "{dist}",
            "dataFile": "{src}/html/data/global.json",
            "renderPath": "{src}/html",
            "htmltidy": {
                "doctype": "html5",
                "hideComments": false,
                "indent": true
            }
        },
        "images": {
            "from": "{src}/images/**/*.{jpg,jpeg,png,gif,svg}",
            "to": "{dist}/assets/images"
        },
        "watch": [
            {
                "task": "static",
                "from": "{src}/static/**/*"
            },
            {
                "task": "images",
                "from": "{src}/images/**/*.{jpg,jpeg,png,gif,svg}"
            },
            {
                "task": "html",
                "from": "{src}/html/**/*.{html,json}"
            },
            {
                "task": "css",
                "from": "{src}/css/**/*.{sass,scss,css}"
            },
            {
                "task": "js",
                "from": "{src}/js/**/*.js"
            }
        ]
    },
    "dependencies": {
        "@fancyapps/fancybox": "^3.5.7",
        "animejs": "^3.2.0",
        "bootstrap": "^5.1.0",
        "debounce": "^1.2.0",
        "imagesloaded": "^4.1.4",
        "isotope-layout": "^3.0.6",
        "isotope-packery": "^2.0.1",
        "jquery": "^3.5.1",
        "masonry-layout": "^4.2.2",
        "object-fit-images": "^3.2.3",
        "rellax": "^1.12.1"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/register": "^7.29.7",
        "autoprefixer": "^10.4.0",
        "babel-loader": "^9.2.1",
        "browser-sync": "^3.0.4",
        "clean-css": "^5.2.2",
        "del": "^5.1.0",
        "eslint": "^8.12.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-plugin-import": "^2.25.4",
        "eslint-plugin-jsx-a11y": "^6.5.1",
        "eslint-plugin-react": "^7.29.4",
        "glob": "^7.2.0",
        "gulp": "^5.0.1",
        "gulp-change": "^1.0.2",
        "gulp-changed": "^4.0.2",
        "gulp-data": "^1.3.1",
        "gulp-header": "^2.0.9",
        "gulp-htmltidy": "^0.2.4",
        "gulp-if": "^3.0.0",
        "gulp-javascript-obfuscator": "^1.1.6",
        "gulp-load-plugins": "^2.0.7",
        "gulp-nunjucks-render": "^2.2.3",
        "gulp-plumber": "^1.2.1",
        "gulp-postcss": "^9.0.1",
        "gulp-prettify": "^0.5.0",
        "gulp-rename": "^2.0.0",
        "gulp-sass": "^5.0.0",
        "gulp-uglify": "^3.0.2",
        "gulp-vinyl-zip": "^2.5.0",
        "husky": "^3.1.0",
        "npm-run-all": "^4.1.5",
        "rafl": "^1.2.2",
        "sass": "^1.49.9",
        "string-template": "^1.0.0",
        "stylelint": "^14.6.1",
        "stylelint-config-recommended-scss": "^6.0.0",
        "stylelint-config-standard": "^25.0.0",
        "stylelint-order": "^5.0.0",
        "stylelint-scss": "^4.2.0",
        "throttle-debounce": "^2.2.1",
        "vinyl-named": "^1.1.0",
        "webpack": "^5.108.4",
        "webpack-stream": "^7.0.0"
    }
}
